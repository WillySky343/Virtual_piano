{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./",

    "target": "ES6",
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],

    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": false,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}
